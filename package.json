		"@types/node": "^22.10.7",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.0.5"
	},
	"packageManager": "pnpm@9.15.4",
	"engines": {
		"node": ">=20"
	}
}
